{
  "name": "@intent-driven/adapter-shadcn",
  "version": "1.2.0",
  "description": "shadcn/ui doodle-style adapter for @intent-driven/renderer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node -e \"const f=require('fs'),s=f.readFileSync('src/theme.css','utf8').replace(/@import \\\"tailwindcss\\\";\\n?/g,'');const i=[];const r=s.replace(/@import\\s+url\\([^)]+\\);\\s*/g,m=>{i.push(m.trim());return''});f.writeFileSync('dist/theme.css',i.join('\\n')+(i.length?'\\n':'')+r)\"",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "@intent-driven/renderer": ">=0.3.0",
    "lucide-react": ">=1.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^4.1.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "@intent-driven/renderer": "workspace:*",
    "lucide-react": "^1.8.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-select": "^2.2.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "clsx": "^2.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Игнат Дубовский <dubovskyy.im@gmail.com>",
  "homepage": "https://github.com/DubovskiyIM/idf-sdk/tree/main/packages/adapter-shadcn",
  "repository": {
    "type": "git",
    "url": "https://github.com/DubovskiyIM/idf-sdk.git",
    "directory": "packages/adapter-shadcn"
  },
  "bugs": {
    "url": "https://github.com/DubovskiyIM/idf-sdk/issues"
  },
  "keywords": [
    "idf",
    "shadcn",
    "ui-adapter",
    "tailwind",
    "react"
  ],
  "sideEffects": [
    "**/*.css"
  ]
}
