{
  "name": "@intent-driven/adapter-mantine",
  "version": "1.2.0",
  "description": "Mantine UI adapter for @intent-driven/renderer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && cp src/theme.css dist/theme.css",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "@mantine/core": ">=9",
    "@mantine/dates": ">=9",
    "@intent-driven/renderer": ">=0.3.0",
    "lucide-react": ">=0.400.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^4.1.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@mantine/core": "^9.0.0",
    "@mantine/dates": "^9.0.0",
    "lucide-react": "^0.400.0",
    "typescript": "^5.7.0",
    "@intent-driven/renderer": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Игнат Дубовский <dubovskyy.im@gmail.com>",
  "homepage": "https://github.com/DubovskiyIM/idf-sdk/tree/main/packages/adapter-mantine",
  "repository": {
    "type": "git",
    "url": "https://github.com/DubovskiyIM/idf-sdk.git",
    "directory": "packages/adapter-mantine"
  },
  "bugs": {
    "url": "https://github.com/DubovskiyIM/idf-sdk/issues"
  },
  "keywords": [
    "idf",
    "mantine",
    "ui-adapter",
    "react"
  ],
  "sideEffects": false
}
