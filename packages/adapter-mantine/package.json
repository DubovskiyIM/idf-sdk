{
  "name": "@idf/adapter-mantine",
  "version": "0.1.0",
  "description": "Mantine UI adapter for @idf/renderer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "@mantine/core": ">=9",
    "@mantine/dates": ">=9",
    "@idf/renderer": ">=0.1.0",
    "lucide-react": ">=0.400.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^4.1.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@mantine/core": "^9.0.0",
    "@mantine/dates": "^9.0.0",
    "lucide-react": "^0.400.0",
    "typescript": "^5.7.0",
    "@idf/renderer": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "http://localhost:4873"
  },
  "license": "MIT"
}
