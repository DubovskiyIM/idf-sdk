# Backend API, который будет получать CRUD-эффекты
VITE_API_URL=http://localhost:4000

# Auth provider (supabase | jwt | none)
VITE_AUTH_PROVIDER=none

# JWT provider:
# VITE_AUTH_SIGN_IN_URL=https://api.example.com/auth/login

# Supabase provider:
# VITE_SUPABASE_URL=https://xyz.supabase.co
# VITE_SUPABASE_ANON_KEY=...

# UI-kit (mantine | shadcn | apple | antd)
VITE_UI_KIT=mantine
