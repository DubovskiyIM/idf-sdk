{
  "name": "@intent-driven/adapter-antd",
  "version": "1.1.0",
  "description": "Ant Design enterprise-fintech adapter for @intent-driven/renderer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18",
    "antd": ">=5",
    "@ant-design/plots": ">=2",
    "@ant-design/icons": ">=5",
    "@intent-driven/renderer": ">=0.3.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^4.1.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "antd": "^6.3.5",
    "@ant-design/plots": "^2.6.8",
    "@ant-design/icons": "^6.1.1",
    "dayjs": "^1.11.0",
    "typescript": "^5.7.0",
    "@intent-driven/renderer": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Игнат Дубовский <dubovskyy.im@gmail.com>",
  "homepage": "https://github.com/DubovskiyIM/idf-sdk/tree/main/packages/adapter-antd",
  "repository": {
    "type": "git",
    "url": "https://github.com/DubovskiyIM/idf-sdk.git",
    "directory": "packages/adapter-antd"
  },
  "bugs": {
    "url": "https://github.com/DubovskiyIM/idf-sdk/issues"
  },
  "keywords": [
    "idf",
    "antd",
    "enterprise",
    "fintech",
    "ui-adapter",
    "react"
  ],
  "sideEffects": false
}
