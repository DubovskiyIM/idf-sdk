{
  "name": "@intent-driven/core",
  "version": "0.69.0",
  "description": "Intent-Driven Frontend — core engine, fold, intent algebra, crystallizer, materializers (pixels/voice/agent-API/document), invariants",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup --watch",
    "generate:candidates": "node scripts/generate-candidates-manifest.mjs"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^4.1.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "BUSL-1.1",
  "author": "Игнат Дубовский <dubovskyy.im@gmail.com>",
  "homepage": "https://github.com/DubovskiyIM/idf-sdk/tree/main/packages/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/DubovskiyIM/idf-sdk.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/DubovskiyIM/idf-sdk/issues"
  },
  "keywords": [
    "idf",
    "intent-driven",
    "fold",
    "crystallize",
    "materialization",
    "ontology",
    "invariants"
  ],
  "sideEffects": false
}
