    "@tiptap/starter-kit": "^3.7.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^4.1.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "antd": "^5.21.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
