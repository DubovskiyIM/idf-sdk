{
  "name": "@idf/canvas-kit",
  "version": "0.1.0",
  "description": "Low-level SVG math/layout utilities for Intent-Driven Frontend canvases",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^4.1.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Игнат Дубовский <dubovskyy.im@gmail.com>",
  "homepage": "https://github.com/ignatdubovskiy/idf-sdk/tree/main/packages/canvas-kit",
  "repository": {
    "type": "git",
    "url": "https://github.com/ignatdubovskiy/idf-sdk.git",
    "directory": "packages/canvas-kit"
  },
  "bugs": {
    "url": "https://github.com/ignatdubovskiy/idf-sdk/issues"
  },
  "keywords": [
    "idf",
    "svg",
    "canvas",
    "visualization",
    "react"
  ],
  "sideEffects": false
}
