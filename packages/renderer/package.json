{
  "name": "@intent-driven/renderer",
  "version": "0.46.0",
  "description": "Intent-Driven Frontend — renderer: primitives, archetypes, controls, adapter registry",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && cp src/tokens.css dist/tokens.css",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18",
    "@intent-driven/core": ">=0.3.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "vitest": "^4.1.0",
    "jsdom": "^25.0.0",
    "@testing-library/react": "^16.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "@intent-driven/core": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Игнат Дубовский <dubovskyy.im@gmail.com>",
  "homepage": "https://github.com/DubovskiyIM/idf-sdk/tree/main/packages/renderer",
  "repository": {
    "type": "git",
    "url": "https://github.com/DubovskiyIM/idf-sdk.git",
    "directory": "packages/renderer"
  },
  "bugs": {
    "url": "https://github.com/DubovskiyIM/idf-sdk/issues"
  },
  "keywords": [
    "idf",
    "intent-driven",
    "renderer",
    "archetypes",
    "primitives",
    "react"
  ],
  "sideEffects": false
}
